{
  "services": {
    "frontend": {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    "backend": {
      "src": "backend/src/server.ts",
      "use": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend"
    },
    {
      "src": "/(.*)",
      "dest": "frontend"
    }
  ]
}
